generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id String @id @default(cuid())

  aoe4Id String @unique

  name String

  country String?

  avatar String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  ratings RatingSnapshot[]

  tracking TrackedPlayer?
}

model RatingSnapshot {
  id String @id @default(cuid())

  playerId String

  leaderboard String

  rating Int

  rank Int?

  wins Int?

  losses Int?

  games Int?

  capturedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([capturedAt])
  @@index([playerId, leaderboard, capturedAt])
}

model TrackedPlayer {
  id String @id @default(cuid())

  playerId String @unique

  active Boolean @default(true)

  lastSynced DateTime?

  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model SyncJob {
  id String @id @default(cuid())

  status String

  startedAt DateTime @default(now())

  completedAt DateTime?

  message String?
}

model HomepageLeaderboardSnapshot {
  id          String   @id @default(cuid())
  key         String   @unique
  generatedAt DateTime
  source      String
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([generatedAt])
}

model PlayerHistoryCache {
  id String @id @default(cuid())

  profileId   Int
  leaderboard String
  historyDays Int

  refreshedAt DateTime
  expiresAt   DateTime

  refreshLeaseUntil DateTime?

  newestGameAt DateTime?
  oldestGameAt DateTime?

  gameCount Int @default(0)

  dataVersion String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games CachedPlayerGame[]

  @@unique([profileId, leaderboard, historyDays])
  @@index([expiresAt])
  @@index([refreshedAt])
  @@index([profileId, leaderboard])
  @@index([refreshLeaseUntil])
}

model CachedPlayerGame {
  id String @id @default(cuid())

  cacheId String
  gameId  String

  profileId   Int
  leaderboard String
  startedAt   DateTime

  data Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cache PlayerHistoryCache @relation(fields: [cacheId], references: [id], onDelete: Cascade)

  @@unique([cacheId, gameId])
  @@index([cacheId, startedAt])
  @@index([profileId, leaderboard, startedAt])
}

model OperationalEvent {
  id String @id @default(cuid())

  eventName String
  route     String?

  statusCode Int?
  durationMs Int?

  profileId   Int?
  historyDays Int?

  cacheSource   String?
  upstreamGames Int?
  returnedGames Int?

  errorCode String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventName, createdAt])
  @@index([route, createdAt])
  @@index([profileId, createdAt])
  @@index([cacheSource, createdAt])
  @@index([errorCode, createdAt])
}
