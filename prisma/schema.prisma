generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Player {
  id String @id @default(cuid())

  aoe4Id String @unique

  name String

  country String?

  avatar String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  ratings RatingSnapshot[]

  tracking TrackedPlayer?
}


model RatingSnapshot {
  id String @id @default(cuid())

  playerId String

  leaderboard String

  rating Int

  rank Int?

  wins Int?

  losses Int?

  games Int?

  capturedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])

  @@index([capturedAt])

  @@index([playerId, leaderboard, capturedAt])
}


model TrackedPlayer {
  id String @id @default(cuid())

  playerId String @unique

  active Boolean @default(true)

  lastSynced DateTime?

  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}


model SyncJob {
  id String @id @default(cuid())

  status String

  startedAt DateTime @default(now())

  completedAt DateTime?

  message String?
}